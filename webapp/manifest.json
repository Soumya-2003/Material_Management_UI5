{
  "_version": "1.83.0",
  "sap.app": {
    "id": "mmui5",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.22.0",
      "toolsId": "a764d3d3-2729-4216-aefb-620395755b74"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/mm/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "4.01"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.147.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "mmui5.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "mmui5.view",
        "async": true,
        "viewPath": "mmui5"
      },
      "routes": [
        {
          "name": "HomeRoute",
          "pattern": "",
          "target": [
            "TargetHome"
          ]
        },
        {
          "name": "RouteDrafts",
          "pattern": "drafts",
          "target": "TargetDrafts"
        },
        {
          "name": "RouteManagerApproval",
          "pattern": "manager-approval",
          "target": "TargetManagerApproval"
        },
        {
          "name": "RouteVendorPortal",
          "pattern": "vendor-portal",
          "target": "TargetVendorPortal"
        },
        {
          "name": "RouteInventory",
          "pattern": "inventory",
          "target": "TargetInventory"
        }
      ],
      "targets": {
        "TargetHome": {
          "id": "home",
          "name": "Home"
        },
        "TargetDrafts": {
          "id": "Drafts",
          "name": "Drafts"
        },
        "TargetManagerApproval": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "name": "ManagerApproval"
        },
        "TargetVendorPortal": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "name": "VendorPortal"
        },
        "TargetInventory": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "name": "Inventory"
        }
      }
    },
    "rootView": {
      "viewName": "mmui5.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
