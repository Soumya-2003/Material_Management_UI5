<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    <Dialog 
        id="itemDetailsDialog" 
        title="Document Quick View" 
        contentWidth="450px"
        class="sapUiResponsivePadding--header sapUiResponsivePadding--content sapUiResponsivePadding--footer">
        
        <content>
            <f:SimpleForm editable="false" layout="ResponsiveGridLayout" labelSpanXL="4" labelSpanL="4" labelSpanM="4">
                <f:content>
                    <Label text="Document No." />
                    <Text text="{detailModel>/title}" class="sapUiTinyMarginTop"/>

                    <Label text="Current Status" />
                    <ObjectStatus text="{detailModel>/subtitle}" state="{detailModel>/statusSchema}" class="sapUiTinyMarginTop"/>

                    <!-- <Label text="Materials" />
                    <Text text="{detailModel>/materialsText}" class="sapUiTinyMarginTop" />

                    <Label text="Vendors" />
                    <Text text="{detailModel>/vendorsText}" class="sapUiTinyMarginTop" /> -->

                    <Label text="Total Value" />
                    <Text text="{detailModel>/amount} INR" class="sapUiTinyMarginTop"/>
                </f:content>
            </f:SimpleForm>
        </content>

        <buttons>
            <Button text="Close" press=".onCloseDetailsDialog" type="Transparent" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>