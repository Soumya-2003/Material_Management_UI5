<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
>
    <Dialog
        id="prWizardDialog"
        title="Create Purchase Requisition"
        contentWidth="800px"
        contentHeight="500px"
        verticalScrolling="false"
    >
        <content>
            <Wizard
                id="CreatePRWizard"
                showNextButton="false"
            >
                <WizardStep
                    id="DataEntryStep"
                    title="Add Materials to PR"
                    validated="false"
                >
                    <f:SimpleForm
                        editable="true"
                        layout="ResponsiveGridLayout"
                        labelSpanXL="3"
                        labelSpanL="3"
                        labelSpanM="3"
                        emptySpanXL="0"
                        emptySpanL="0"
                        emptySpanM="0"
                        columnsXL="1"
                        columnsL="1"
                        columnsM="1"
                    >
                        <f:content>
                            <Label text="PR Number" />
                            <Input
                                value="{wizardModel>/prNumber}"
                                editable="false"
                            />

                            <Label
                                text="Material"
                                required="true"
                            />
                            <ComboBox
                                id="materialSelect"
                                items="{/Materials}"
                                selectedKey="{wizardModel>/currentItem/materialId}"
                                change=".onFormChange"
                                width="100%"
                            >
                                <core:Item
                                    key="{ID}"
                                    text="{name} (Price: {price} {unit})"
                                />
                            </ComboBox>

                            <Label
                                text="Vendor"
                                required="true"
                            />
                            <ComboBox
                                id="vendorSelect"
                                items="{
                                path: '/VendorMaterials',
                                parameters: {
                                    $expand: 'vendor'
                                }
                            }"
                                selectedKey="{wizardModel>/currentItem/vendorId}"
                                change=".onFormChange"
                                width="100%"
                                enabled="{= ${wizardModel>/currentItem/materialId} !== '' }"
                            >
                                <core:Item
                                    key="{vendor_ID}"
                                    text="{vendor/name} (Rating: {vendor/rating})"
                                />
                            </ComboBox>

                            <Label
                                text="Quantity"
                                required="true"
                            />
                            <Input
                                id="quantityInput"
                                type="Number"
                                value="{wizardModel>/currentItem/quantity}"
                                liveChange=".onFormChange"
                                placeholder="Enter quantity"
                            />

                            <Label text="" />
                            <Button
                                text="Add to PR"
                                press=".onAddItem"
                                type="Emphasized"
                                enabled="{wizardModel>/addItemEnabled}"
                                width="150px"
                            />
                        </f:content>
                    </f:SimpleForm>

                    <Table
                        items="{wizardModel>/draftItems}"
                        noDataText="No materials added yet."
                        class="sapUiSmallMarginTop"
                    >
                        <columns>
                            <Column>
                                <Text text="Material" />
                            </Column>
                            <Column>
                                <Text text="Vendor" />
                            </Column>
                            <Column hAlign="End">
                                <Text text="Qty" />
                            </Column>
                            <Column hAlign="End">
                                <Text text="Total" />
                            </Column>
                            <Column
                                hAlign="Center"
                                width="6rem"
                            >
                                <Text text="" />
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{wizardModel>materialText}" />
                                    <Text text="{wizardModel>vendorText}" />
                                    <Text text="{wizardModel>quantity}" />
                                    <Text text="{wizardModel>itemTotal} INR" />
                                    <HBox justifyContent="End">
                                        <Button
                                            icon="sap-icon://edit"
                                            type="Transparent"
                                            press=".onEditItem"
                                            class="sapUiTinyMarginEnd"
                                        />
                                        <Button
                                            icon="sap-icon://delete"
                                            type="Transparent"
                                            press=".onRemoveItem"
                                        />
                                    </HBox>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>

                    <HBox
                        justifyContent="End"
                        class="sapUiSmallMarginTop"
                    >
                        <Title
                            text="Grand Total: {wizardModel>/totalPrice} USD"
                            level="H5"
                        />
                    </HBox>
                </WizardStep>

                <WizardStep
                    id="ReviewStep"
                    title="Review PR"
                >
                    <Table
                        items="{wizardModel>/draftItems}"
                        mode="None"
                    >
                        <columns>
                            <Column>
                                <Text text="Material" />
                            </Column>
                            <Column>
                                <Text text="Vendor" />
                            </Column>
                            <Column hAlign="End">
                                <Text text="Qty" />
                            </Column>
                            <Column hAlign="End">
                                <Text text="Total" />
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{wizardModel>materialText}" />
                                    <Text text="{wizardModel>vendorText}" />
                                    <Text text="{wizardModel>quantity}" />
                                    <Text text="{wizardModel>itemTotal} USD" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>

                    <HBox
                        justifyContent="End"
                        class="sapUiSmallMarginTop"
                    >
                        <Title
                            text="Grand Total: {wizardModel>/totalPrice} USD"
                            level="H4"
                        />
                    </HBox>

                    <VBox class="sapUiMediumMarginTop">
                        <CheckBox
                            id="confirmCheck"
                            text="I confirm the above details are correct."
                            selected="{wizardModel>/isConfirmed}"
                        />
                    </VBox>
                </WizardStep>
            </Wizard>
        </content>
        <buttons>
            <Button
                id="btnPrev"
                text="Previous"
                press=".onPrevStep"
                visible="{wizardModel>/isLastStep}"
            />
            <Button
                id="btnNext"
                text="Next"
                type="Emphasized"
                press=".onNextStep"
                visible="{wizardModel>/isFirstStep}"
                enabled="{wizardModel>/nextEnabled}"
            />

            <Button
                id="btnDraft"
                text="Save as Draft"
                press=".onSaveDraft"
                visible="{wizardModel>/isLastStep}"
            />

            <Button
                id="btnSubmit"
                text="Submit PR"
                type="Emphasized"
                press=".onSubmitPR"
                visible="{= ${wizardModel>/isLastStep} === true &amp;&amp; ${wizardModel>/isConfirmed} === true }"
            />

            <Button
                text="Cancel"
                press=".onCloseDialog"
                type="Transparent"
            />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
