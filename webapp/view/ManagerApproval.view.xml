<mvc:View controllerName="mmui5.controller.ManagerApproval"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    
    <Page title="Manager Approval Dashboard" showNavButton="true" navButtonPress=".onNavBack">
        <content>
            <IconTabBar id="approvalTabBar" expandable="false" class="sapUiResponsiveContentPadding">
                <items>
                    <IconTabFilter icon="sap-icon://approvals" iconColor="Critical" text="Action Required" key="pending">
                        <Table id="pendingTable" 
                               items="{
                                   path: '/PR_Items',
                                   parameters: {
                                       $filter: 'status eq \'IN_APPROVAL\'',
                                       $expand: 'pr,material,vendor'
                                   }
                               }"
                               noDataText="No PR items waiting for approval.">
                            <columns>
                                <Column><Text text="PR Ref" /></Column>
                                <Column><Text text="Material" /></Column>
                                <Column><Text text="Vendor" /></Column>
                                <Column><Text text="Qty" /></Column>
                                <Column hAlign="End"><Text text="Actions" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <ObjectIdentifier title="{pr/prNumber}" text="Total PR: {pr/totalAmount}" />
                                        <Text text="{material/name}" />
                                        <Text text="{vendor/name}" />
                                        <Text text="{quantity}" />
                                        <HBox justifyContent="End">
                                            <Button icon="sap-icon://accept" type="Success" press=".onApprove" class="sapUiTinyMarginEnd" tooltip="Approve"/>
                                            <Button icon="sap-icon://decline" type="Reject" press=".onReject" tooltip="Reject"/>
                                        </HBox>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </IconTabFilter>

                    <IconTabFilter icon="sap-icon://history" iconColor="Default" text="Processed" key="processed">
                        <Table id="processedTable" 
                               items="{
                                   path: '/PR_Items',
                                   parameters: {
                                       $filter: 'status eq \'APPROVED\' or status eq \'REJECTED\'',
                                       $expand: 'pr,material,vendor'
                                   }
                               }"
                               noDataText="No processed Items found.">
                            <columns>
                                <Column><Text text="PR Ref" /></Column>
                                <Column><Text text="Material" /></Column>
                                <Column><Text text="Vendor" /></Column>
                                <Column><Text text="Status" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{pr/prNumber}" />
                                        <Text text="{material/name}" />
                                        <Text text="{vendor/name}" />
                                        <ObjectStatus 
                                            text="{status}" 
                                            state="{= ${status} === 'APPROVED' ? 'Success' : 'Error' }" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
    </Page>
</mvc:View>